QPushButton {
    background: transparent;
    border: none;
    border-radius: 6px;
    color: #D8D8F6;
}

QPushButton:hover {
    background: rgba(255,255,255,0.3);
}

    QPushButton:pressed {
        background: rgba(255,255,255,0.16);
    }

QPushButton#CloseApplication:hover {
    background: #c42b1c;
}

#HintConstraint
{
    background: rgba(255, 255, 255, 0.5);
    border: none;
    border-radius: 6px;
    color: #D8D8F6;
     image-position: center;

    padding: 0px;
    margin: 0px;
    spacing: 0px;
}

#ActiveTool {
    background: rgba(255, 255, 255, 0.3);
    border: none;
    border-radius: 6px;
    color: #D8D8F6;
     image-position: center;

    padding: 0px;
    margin: 0px;
    spacing: 0px;
}
#NoActiveTool {
    background: transparent;
    border: none;
    border-radius: 6px;
    color: #D8D8F6;
    image-position: center;

    padding: 0px;
    margin: 0px;
    spacing: 0px;
}


#InfoButton,#MesButton {
    background: transparent;
    border: none;
    color: #D8D8F6;
    border-radius: 6px;
    padding: 6px;
}

#InfoButton:hover ,#MesButton:hover {
    background: rgba(255, 255, 255, 0.3);
}

#InfoButton:pressed ,#MesButton:pressed {
    background: rgba(255,255,255,0.16);
}

#NoActiveTool::menu-indicator {
    image: none;              /* убираем стрелку меню */
}
#ActiveTool::menu-indicator {
    image: none;              /* убираем стрелку меню */
}

#ActiveTool:hover, #NoActiveTool:hover {
    background: rgba(255, 255, 255, 0.3);
}

#ActiveTool:pressed, #NoActiveTool:pressed {
    background: rgba(255, 255, 255, 0.16);
}

QPushButton {
    image-position: center;
}

#ActiveTool QPushButton::icon {
    position: relative;
    left: 0px;
    top: 0px;
}
#NoActiveTool QPushButton::icon {
    position: relative;
    left: 0px;
    top: 0px;
}

